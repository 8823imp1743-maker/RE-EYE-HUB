# ===========================================
# RE-EYE-HUB 通知エンジン 環境変数
# ===========================================

# --- Webhook セキュリティ ---
# X-Webhook-Secret ヘッダと照合。一致しなければ 401
WEBHOOK_SECRET=your-webhook-secret-string

# --- Upstash Redis ---
# https://console.upstash.com/ で作成
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# --- OneSignal ---
# https://dashboard.onesignal.com/ > アプリ > Settings > Keys & IDs
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_API_KEY=Your-REST-API-Key
# テスト中のみ: 指定 userId のみプッシュ（data.userId 不一致は safety_lock_active、無しは safety_lock_skip_non_user_target）
# RE_EYE_ADMIN_LOCK_ENABLE=1
# RE_EYE_ADMIN_ONLY_USER_ID=your-test-user-id
# 画面で size_27 タグ同期済みのクライアントに絞る場合のみ 1（未設定=0: userId のみでターゲット）
# ONESIGNAL_USE_SIZE_TAG_FILTERS=1
# monitor / poll のユーザー別プッシュ合計（1分窓）。無料プラン急増時の保険
# MONITOR_PUSH_MAX_PER_USER_PER_MIN=20
# 追加の保険（5分 / 1日）。Digest を有効化する場合もこの上限に含める
# MONITOR_PUSH_MAX_PER_USER_PER_5MIN=80
# MONITOR_PUSH_MAX_PER_USER_PER_DAY=500

# --- 運用完成パック（初日は [re_eye_ops] で notify_per_min / notification_send / notification_zero_delivery を確認）---
# 無料の「体感遅延」は Digest 5分バケット＋paid_fast で有料即時 に寄せる（lib/digest.js の JST bucket）
#
# タグフィルタ段階導入:
#ONESIGNAL_USE_SIZE_TAG_FILTERS=1
#RE_EYE_TAG_FILTER_ROLLOUT_PCT=30
#
# --- 運用・CTR / LTV（Cloud Logging で [re_eye_ops] を検索）---
# ONESIGNAL へのタグ AND 適用ユーザー割合 0〜100（段階導入: 10→30→…→100）
# RE_EYE_TAG_FILTER_ROLLOUT_PCT=10
# FREE のみ「通知の質」スコアがこの未満なら送らない（0 で無効）
# RE_EYE_LTV_MIN_SCORE_FREE=3
# Digest: all（全員Digest経由） | paid_fast（無料のみDigest・有料は即時）
# RE_EYE_DIGEST_SCOPE=paid_fast
# 無料ユーザーの同日送信上限（未設定または0で無制限）
# RE_EYE_FREE_NOTIFY_DAILY_MAX=5
#
# CTR Redis 集計: ctr:sent:{template} / ctr:click:{template}（POST /api/ctr-click）
# FREEのみ「CTRブーストスコア」閾値（0=無効／例:60）
# RE_EYE_CTR_BOOST_MIN_SCORE_FREE=60
# 無料の最短送信間隔（秒・未設定で既定120／0で無効）
# RE_EYE_FREE_PUSH_MIN_GAP_SEC=120
# FREE即時のみ JST でオフピークなら送信スキップ（Digestに逃がしていないとき）
# RE_EYE_FREE_PEAK_DEFER=0
# ctr_dashboard で勝ちテンプレ候補にするクリック率判定の最短送信サンプル数
# RE_EYE_CTR_WINNER_MIN_SENT=12

# --- Digest（5分まとめ） ---
# 1 にすると monitor / poll の通知を digest（自己回収 flush）に寄せる
# RE_EYE_DIGEST_ENABLE=1

# ===========================================
# ショップAPI（3強監視エンジン）
# ===========================================

# --- 楽天市場 ---
# https://webservice.rakuten.co.jp/ アプリ一覧で App ID と Access Key（両方必須）
RAKUTEN_APP_ID=your-rakuten-app-id
RAKUTEN_ACCESS_KEY=your-rakuten-access-key

# --- Yahoo!ショッピング ---
# https://e.developer.yahoo.co.jp/ でアプリID取得（無料・即日）
YAHOO_APP_ID=your-yahoo-app-id

# --- Amazon PA-API 5.0 ---
# https://affiliate.amazon.co.jp/ でアソシエイト登録後、PA-API認証情報を取得
# ※ 180日以内に3件の購買紹介が必要。未取得の場合はこの3行を空欄にするとAmazonはスキップされる
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_PARTNER_TAG=your-tag-22

# ===========================================
# Vercel /api/* (CORS + レート制限: api/_security.js)
# ===========================================
# カンマ区切りで「追加」（上記既定オリジンとマージ済み。.web.app 等を消さず足すだけでよい）
# 未設定なら既定のみ: https://re-eye-hub.vercel.app / .web.app / .firebaseapp.com
# RE_EYE_ALLOWED_ORIGINS=https://re-eye-hub.vercel.app,https://re-eye-hub.web.app
# ローカルから Functions を直接叩く場合の例
# RE_EYE_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
# 緊急のみ: CORS を * に緩和（本番非推奨）。レート制限は tier 設定に従う
# RE_EYE_RELAX_CORS=1
# プレビューデプロイ re-eye-*.vercel.app を許可
# RE_EYE_ALLOW_VERCEL_PREV=1
# 60秒窓あたりの上限（デフォルト: search=24, heavy=40, default=120）
# RE_EYE_RL_SEARCH_MAX=24
# RE_EYE_RL_HEAVY_MAX=40
# RE_EYE_RL_DEFAULT_MAX=120
# 障害調査時のみ
# RE_EYE_DISABLE_RATE_LIMIT=1

# --- Google Shopping 代替（lib/google-shopping.js）---
# SERPAPI_KEY=

# --- オプション ---
# RE_EYE_CLI=1
# RE_EYE_MONITOR_DEBUG=1
