{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  },
  "functions": {
    "source": ".",
    "ignore": [
      "public/**",
      ".vercel/**",
      ".git/**",
      "node_modules/**",
      "firebase.json",
      ".firebaserc",
      "*.md",
      ".env*"
    ]
  }
}
